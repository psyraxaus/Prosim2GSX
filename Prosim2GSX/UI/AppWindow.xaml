<Window x:Class="Prosim2GSX.UI.AppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Prosim2GSX.UI"
        mc:Ignorable="d"
        Title="Prosim2GSX"
        Width="820"
        MinWidth="820"
        SizeToContent="Height"
        ResizeMode="CanMinimize"
        Background="{DynamicResource ContentBackgroundBrush}"
        Foreground="{DynamicResource ContentText}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header Bar -->
        <local:HeaderBarControl Grid.Row="0" Height="60"/>

        <!-- Row 1: SDK Warning Banner (degraded mode) -->
        <Border Grid.Row="1" Name="PanelSdkWarning" Visibility="Collapsed"
                Background="#FFF3CD" BorderBrush="#FFCC02" BorderThickness="0,0,0,2" Padding="10,8">
            <TextBlock Name="LabelSdkWarning" FontWeight="DemiBold" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextWrapping="Wrap" Foreground="#664D03"/>
        </Border>

        <!-- Row 2: Version Check -->
        <StackPanel Grid.Row="2" Name="PanelVersion" Visibility="Collapsed" Orientation="Horizontal" HorizontalAlignment="Center" Margin="8">
            <TextBlock Name="LabelVersionCheck" FontWeight="DemiBold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 3: Main Tab Control -->
        <TabControl Grid.Row="3" x:Name="MainTabControl" Margin="0" Padding="0"
                    Style="{StaticResource EfbTabControl}">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource EfbTabItem}"/>
            </TabControl.Resources>
            <TabItem Header="FLIGHT STATUS"/>
            <TabItem Header="AUTOMATION"/>
            <TabItem Header="AIRCRAFT PROFILES"/>
            <TabItem Header="AUDIO SETTINGS"/>
            <TabItem Header="APP SETTINGS"/>
        </TabControl>
    </Grid>
</Window>
