<UserControl x:Class="Prosim2GSX.UI.Views.Checklists.ViewChecklist"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Checklists"
             d:DataContext="{d:DesignInstance Type=local:ModelChecklist}"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="820"
             Background="{DynamicResource ChecklistBackgroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ECAM-style row templates. The ItemsControl uses a
                 DataTemplateSelector to pick one of these per row based on the
                 ChecklistItemView projection (separator / note / checked /
                 current / pending). All five share the same Grid skeleton so
                 the dotted fill column lines up across rows. -->

            <DataTemplate x:Key="ChecklistRowSeparator">
                <Separator Margin="6,4,6,4" Background="{DynamicResource ChecklistSeparatorBrush}" Height="1"/>
            </DataTemplate>

            <DataTemplate x:Key="ChecklistRowNote">
                <TextBlock Text="{Binding Label}"
                           FontFamily="Consolas"
                           FontStyle="Italic"
                           FontSize="13"
                           Foreground="{DynamicResource ChecklistNoteForeground}"
                           Margin="32,2,8,2"/>
            </DataTemplate>

            <DataTemplate x:Key="ChecklistRowChecked">
                <Grid Margin="4,1,4,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="✓"
                               FontFamily="Consolas"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ChecklistCheckedForeground}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistCheckedForeground}"/>
                    <TextBlock Grid.Column="2" Text="...................................................................................................."
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistCheckedForeground}"
                               TextTrimming="CharacterEllipsis"
                               Margin="4,0,4,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Value}"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistCheckedForeground}"
                               Visibility="{Binding HasValue, Converter={StaticResource BoolVisibilityConverter}}"/>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="ChecklistRowCurrent">
                <Border BorderBrush="{DynamicResource ChecklistCurrentHighlightBorder}"
                        BorderThickness="1"
                        Padding="2"
                        Margin="2,1,2,1"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick"
                                      Command="{Binding DataContext.ItemClickCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      CommandParameter="{Binding}"/>
                    </Border.InputBindings>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="□"
                                   FontFamily="Consolas"
                                   FontSize="14"
                                   Foreground="{DynamicResource ChecklistPendingForeground}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Label}"
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="{DynamicResource ChecklistPendingForeground}"/>
                        <TextBlock Grid.Column="2" Text="...................................................................................................."
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="{DynamicResource ChecklistPendingForeground}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="4,0,4,0"/>
                        <TextBlock Grid.Column="3" Text="{Binding Value}"
                                   FontFamily="Consolas" FontSize="14"
                                   Foreground="{DynamicResource ChecklistPendingForeground}"
                                   Visibility="{Binding HasValue, Converter={StaticResource BoolVisibilityConverter}}"/>
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="ChecklistRowPending">
                <Grid Margin="4,1,4,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="1" Text="{Binding Label}"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistPendingForeground}"/>
                    <TextBlock Grid.Column="2" Text="...................................................................................................."
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistPendingForeground}"
                               TextTrimming="CharacterEllipsis"
                               Margin="4,0,4,0"/>
                    <TextBlock Grid.Column="3" Text="{Binding Value}"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="{DynamicResource ChecklistPendingForeground}"
                               Visibility="{Binding HasValue, Converter={StaticResource BoolVisibilityConverter}}"/>
                </Grid>
            </DataTemplate>

            <local:ChecklistItemTemplateSelector x:Key="ChecklistItemTemplateSelector"
                                                 SeparatorTemplate="{StaticResource ChecklistRowSeparator}"
                                                 NoteTemplate="{StaticResource ChecklistRowNote}"
                                                 CheckedTemplate="{StaticResource ChecklistRowChecked}"
                                                 CurrentTemplate="{StaticResource ChecklistRowCurrent}"
                                                 PendingTemplate="{StaticResource ChecklistRowPending}"/>

            <!-- Wrapper template: a single ContentPresenter whose ContentTemplate
                 swaps via DataTriggers as IsChecked / IsCurrentItem flip. The
                 ItemTemplateSelector above is only consulted at item-container
                 creation, so it does not respond to live state changes; this
                 indirection lets per-tick state flips repaint the row. -->
            <DataTemplate x:Key="ChecklistRowSwitcher">
                <ContentPresenter x:Name="RowPresenter"
                                  Content="{Binding}"
                                  ContentTemplate="{StaticResource ChecklistRowPending}"/>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                        <Setter TargetName="RowPresenter" Property="ContentTemplate" Value="{StaticResource ChecklistRowSeparator}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsNote}" Value="True">
                        <Setter TargetName="RowPresenter" Property="ContentTemplate" Value="{StaticResource ChecklistRowNote}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                        <Setter TargetName="RowPresenter" Property="ContentTemplate" Value="{StaticResource ChecklistRowChecked}"/>
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsChecked}" Value="False"/>
                            <Condition Binding="{Binding IsCurrentItem}" Value="True"/>
                            <Condition Binding="{Binding IsNote}" Value="False"/>
                            <Condition Binding="{Binding IsSeparator}" Value="False"/>
                        </MultiDataTrigger.Conditions>
                        <Setter TargetName="RowPresenter" Property="ContentTemplate" Value="{StaticResource ChecklistRowCurrent}"/>
                    </MultiDataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate>

            <Style x:Key="ChecklistButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ChecklistButtonBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource ChecklistButtonForeground}"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ChecklistCurrentHighlightBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="14,4"/>
                <Setter Property="Margin" Value="4,0,4,0"/>
                <Setter Property="MinWidth" Value="110"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- C/L COMPLETE button: turns full ECAM-green when every item in
                 the active section is checked, signalling the user can advance. -->
            <Style x:Key="ChecklistCompleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ChecklistButtonStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSectionComplete}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource ChecklistCheckedForeground}"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ChecklistCheckedForeground}"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top header bar: checklist set selector + airline label -->
        <Border Grid.Row="0" Background="{DynamicResource ChecklistHeaderBackgroundBrush}" Padding="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="C/L"
                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ChecklistPendingForeground}"
                               Margin="6,0,8,0"/>
                    <ComboBox x:Name="ChecklistSetCombo"
                              MinWidth="220"
                              ItemsSource="{Binding AvailableChecklists}"
                              SelectedItem="{Binding CurrentChecklistName, Mode=TwoWay}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Section dropdown bar -->
        <Border Grid.Row="1" Background="{DynamicResource ChecklistHeaderBackgroundBrush}" Padding="6,2,6,6">
            <ComboBox x:Name="SectionCombo"
                      MinWidth="260"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding Sections}"
                      SelectedItem="{Binding CurrentSection, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </Border>

        <!-- Item list -->
        <Border Grid.Row="2" Background="{DynamicResource ChecklistBackgroundBrush}" Padding="4,8,4,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding CurrentItems}"
                              ItemTemplate="{StaticResource ChecklistRowSwitcher}"/>
            </ScrollViewer>
        </Border>

        <!-- Footer buttons -->
        <Border Grid.Row="3" Background="{DynamicResource ChecklistHeaderBackgroundBrush}" Padding="6,8,6,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource ChecklistButtonStyle}"
                        Content="RESET"
                        Command="{Binding ResetCommand}"/>
                <Button Style="{StaticResource ChecklistButtonStyle}"
                        Content="C/L MENU"
                        Command="{Binding FocusSectionDropdownCommand}"/>
                <Button Style="{StaticResource ChecklistButtonStyle}"
                        Content="MSG LIST"
                        IsEnabled="False"/>
                <Button Style="{StaticResource ChecklistCompleteButtonStyle}"
                        Content="C/L COMPLETE"
                        Command="{Binding CompleteCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
