<UserControl x:Class="Prosim2GSX.UI.Views.Ofp.ViewOfp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Ofp"
             xmlns:controls="clr-namespace:Prosim2GSX.UI"
             d:DataContext="{d:DesignInstance Type=local:ModelOfp}"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,8">

            <!-- FLIGHT PLAN — read-only summary of EfbFlightPlanState.CurrentOfp.
                 Fetching, MCDU auto-fetch, and per-field overrides live on the
                 web INIT page; this card just shows whichever OFP is currently
                 loaded so the desktop user has the same situational awareness
                 without launching a browser. Two-column layout: identification
                 + routing on the left, loadout + timing on the right. -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="FLIGHT PLAN" Margin="0,0,0,4"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <Grid Visibility="{Binding HasFlightPlan, Converter={StaticResource BoolVisibilityConverter}}" Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: identification + routing -->
                        <Grid Grid.Column="0" Margin="0,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">FLT NBR</Label>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding FlightNumber}"/>

                            <Label Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">CALLSIGN</Label>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding Callsign}"/>

                            <Label Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">FROM/TO</Label>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontWeight="Bold" Text="{Binding FpDeparture}"/>
                                <TextBlock Foreground="{DynamicResource CategoryTextBrush}" Text=" → "/>
                                <TextBlock FontWeight="Bold" Text="{Binding FpArrival}"/>
                                <TextBlock Foreground="{DynamicResource CategoryTextBrush}" Text="   ALTN "/>
                                <TextBlock FontWeight="Bold" Text="{Binding FpAlternate}"/>
                            </StackPanel>

                            <Label Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">RWY OUT/IN</Label>
                            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontWeight="Bold" Text="{Binding DeparturePlanRwy}"/>
                                <TextBlock Foreground="{DynamicResource CategoryTextBrush}" Text=" / "/>
                                <TextBlock FontWeight="Bold" Text="{Binding ArrivalPlanRwy}"/>
                            </StackPanel>

                            <Label Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">ACFT</Label>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontWeight="Bold" Text="{Binding AircraftType}"/>
                                <TextBlock Foreground="{DynamicResource CategoryTextBrush}" Text="   REG "/>
                                <TextBlock FontWeight="Bold" Text="{Binding AircraftReg}"/>
                            </StackPanel>

                            <Label Grid.Row="5" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">CRZ FL</Label>
                            <TextBlock Grid.Row="5" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding CruiseFlText}"/>
                        </Grid>

                        <!-- RIGHT: timing + loadout -->
                        <Grid Grid.Column="1" Margin="8,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">STD</Label>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding StdZulu}"/>

                            <Label Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">ETA</Label>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding EtaZulu}"/>

                            <Label Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">ZFW</Label>
                            <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding ZfwKgText}"/>

                            <Label Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">BLOCK FUEL</Label>
                            <TextBlock Grid.Row="3" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding BlockFuelKgText}"/>

                            <Label Grid.Row="4" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">PAX</Label>
                            <TextBlock Grid.Row="4" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding PaxCountText}"/>

                            <Label Grid.Row="5" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">CARGO</Label>
                            <TextBlock Grid.Row="5" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding CargoKgText}"/>
                        </Grid>
                    </Grid>

                    <!-- Footer line — fetched-at timestamp + a hint pointing the
                         user at the web INIT page when they want to fetch / edit. -->
                    <DockPanel Visibility="{Binding HasFlightPlan, Converter={StaticResource BoolVisibilityConverter}}"
                               Margin="6,2,6,4">
                        <TextBlock DockPanel.Dock="Right"
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Text="Fetch &amp; overrides on the web INIT page"/>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Text="{Binding FetchedAtText}"/>
                    </DockPanel>

                    <TextBlock Text="No flight plan loaded — enter origin/destination on the MCDU, or fetch an OFP from the INIT page on the web interface."
                               FontStyle="Italic"
                               Foreground="{DynamicResource CategoryTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="6,8,6,8"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasNoFlightPlan, Converter={StaticResource BoolVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- PUSHBACK DIRECTION -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="PUSHBACK DIRECTION" Margin="0,8,0,4"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <UniformGrid Rows="1" Columns="3" HorizontalAlignment="Center" Margin="6,4,6,4">
                    <controls:KorryPushbackButton Arrow="TailLeft"
                                                  Label="TAIL LEFT"
                                                  Subtitle="NOSE RIGHT"
                                                  IsActive="{Binding PushbackPrefIsTailLeft, Mode=TwoWay}"
                                                  Margin="8,0,8,0"
                                                  ToolTip="Auto-select 'Nose Right/Tail Left' when GSX shows the direction menu."/>
                    <controls:KorryPushbackButton Arrow="Straight"
                                                  Label="STRAIGHT"
                                                  Subtitle="STRAIGHT BACK"
                                                  IsActive="{Binding PushbackPrefIsStraight, Mode=TwoWay}"
                                                  Margin="8,0,8,0"
                                                  ToolTip="Auto-select 'Straight pushback' when GSX shows the direction menu."/>
                    <controls:KorryPushbackButton Arrow="TailRight"
                                                  Label="TAIL RIGHT"
                                                  Subtitle="NOSE LEFT"
                                                  IsActive="{Binding PushbackPrefIsTailRight, Mode=TwoWay}"
                                                  Margin="8,0,8,0"
                                                  ToolTip="Auto-select 'Nose Left/Tail Right' when GSX shows the direction menu."/>
                </UniformGrid>
            </Border>

            <!-- ARRIVAL GATE ASSIGNMENT -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="ARRIVAL GATE ASSIGNMENT" Margin="0,8,0,4"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <StackPanel Visibility="{Binding IsOfpLoaded, Converter={StaticResource BoolVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Margin="6,4,6,4">
                            <Label Width="80" VerticalAlignment="Center" Foreground="{DynamicResource CategoryTextBrush}">Arrival</Label>
                            <TextBlock Text="{Binding ArrivalIcao}" FontWeight="Bold" VerticalAlignment="Center" MinWidth="60"/>
                            <Label Width="50" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="{DynamicResource CategoryTextBrush}">Gate</Label>
                            <TextBox Text="{Binding ArrivalGate, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource TextBoxCentered}"
                                     IsEnabled="{Binding IsOfpLoaded}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="6,8,6,4">
                            <Button Content="Send Now"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SendNowCommand}"
                                    Margin="0,0,6,0"
                                    Padding="12,4,12,4"
                                    ToolTip="Send the queued arrival gate to ATC and GSX immediately, without waiting for cruise phase."/>
                            <Button Content="Confirm"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmArrivalGateCommand}"
                                    Padding="12,4,12,4"
                                    ToolTip="Queue the arrival gate. It will be sent to ATC and GSX automatically when reaching cruise."/>
                        </StackPanel>
                        <TextBlock Text="{Binding GateAssignmentStatus}"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="6,2,6,2"
                                   Visibility="{Binding GateAssignmentStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding GsxAssignmentStatus}"
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="6,0,6,4"
                                   Visibility="{Binding GsxAssignmentStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="6,0,6,4"
                                    Visibility="{Binding HasAssignedArrivalGate, Converter={StaticResource BoolVisibilityConverter}}">
                            <TextBlock Text="GSX assigned: "
                                       Foreground="{DynamicResource CategoryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AssignedArrivalGate}"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Load an OFP to enable gate assignment"
                               FontStyle="Italic"
                               Foreground="{DynamicResource CategoryTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="6,8,6,8"
                               Visibility="{Binding IsOfpNotLoaded, Converter={StaticResource BoolVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- WEATHER (ATIS / METAR) -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource CategoryHeader}" Text="WEATHER (SAYINTENTIONS)"/>
                <Button Grid.Column="1"
                        Content="Refresh"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RefreshWeatherCommand}"
                        Padding="10,2,10,2"
                        VerticalAlignment="Center"/>
            </Grid>
            <!-- CPDLC + status share the line under the WEATHER header — the
                 CPDLC station is fetched alongside weather (same SayIntentions
                 round-trip) so they live together. -->
            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                <TextBlock Text="CPDLC: "
                           Foreground="{DynamicResource CategoryTextBrush}"
                           Visibility="{Binding HasCpdlcStation, Converter={StaticResource BoolVisibilityConverter}}"/>
                <TextBlock Text="{Binding CpdlcStation}"
                           FontWeight="Bold"
                           Margin="0,0,12,0"
                           Visibility="{Binding HasCpdlcStation, Converter={StaticResource BoolVisibilityConverter}}"
                           ToolTip="CPDLC logon station for the airport SayIntentions currently considers active (departure → arrival as the flight progresses). Enter on the MCDU when requesting clearance."/>
                <TextBlock Text="{Binding WeatherStatus}"
                           FontStyle="Italic"
                           Foreground="{DynamicResource CategoryTextBrush}"
                           Visibility="{Binding WeatherStatus, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Departure WX -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardBorder}" Margin="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="DEPARTURE" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}"/>
                        <TextBlock Text="{Binding DepartureIcao}" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                        <StackPanel Visibility="{Binding HasDepartureWeather, Converter={StaticResource BoolVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <TextBlock Text="RWY " Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding DepartureWeather.ActiveRunway}" FontWeight="Bold"/>
                                <TextBlock Text="   Wind " Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding DepartureWeather.WindDirection}"/>
                                <TextBlock Text="°/" Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding DepartureWeather.WindSpeed}"/>
                                <TextBlock Text="kt" Foreground="{DynamicResource CategoryTextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="METAR" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding DepartureWeather.Metar}" TextWrapping="Wrap"/>
                            <TextBlock Text="ATIS" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding DepartureWeather.Atis}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="No data."
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Visibility="{Binding HasNoDepartureWeather, Converter={StaticResource BoolVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
                <!-- Arrival WX -->
                <Border Grid.Column="1" Style="{StaticResource SectionCardBorder}" Margin="4,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ARRIVAL" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}"/>
                        <TextBlock Text="{Binding ArrivalIcao}" FontWeight="Bold" FontSize="16" Margin="0,0,0,6"/>
                        <StackPanel Visibility="{Binding HasArrivalWeather, Converter={StaticResource BoolVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                <TextBlock Text="RWY " Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding ArrivalWeather.ActiveRunway}" FontWeight="Bold"/>
                                <TextBlock Text="   Wind " Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding ArrivalWeather.WindDirection}"/>
                                <TextBlock Text="°/" Foreground="{DynamicResource CategoryTextBrush}"/>
                                <TextBlock Text="{Binding ArrivalWeather.WindSpeed}"/>
                                <TextBlock Text="kt" Foreground="{DynamicResource CategoryTextBrush}"/>
                            </StackPanel>
                            <TextBlock Text="METAR" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ArrivalWeather.Metar}" TextWrapping="Wrap"/>
                            <TextBlock Text="ATIS" FontWeight="DemiBold" Foreground="{DynamicResource CategoryTextBrush}" Margin="0,6,0,0"/>
                            <TextBlock Text="{Binding ArrivalWeather.Atis}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="No data."
                                   FontStyle="Italic"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Visibility="{Binding HasNoArrivalWeather, Converter={StaticResource BoolVisibilityConverter}}"/>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
