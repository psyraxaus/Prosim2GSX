<UserControl x:Class="Prosim2GSX.UI.Views.Automation.ControlGsxServices"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Automation"
             d:DataContext="{d:DesignInstance Type=local:ModelAutomation}"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel Margin="12,8,12,8">

        <!-- SERVICE CALLS -->
        <TextBlock Style="{StaticResource CategoryHeader}" Text="SERVICE CALLS" Margin="0,0,0,4"/>
        <Border Style="{StaticResource SectionCardBorder}" ToolTip="Configure which GSX Services are called by Prosim2GSX and when they are called.">
            <StackPanel>
                <CheckBox IsChecked="{Binding CallReposition}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Automatically Reposition the Aircraft via GSX Menu on Session Start.&#x0a;Note: Do NOT use both the GSX Setting and this Option to Reposition the Plane at the same Time!">
                    <TextBlock><Underline>Reposition</Underline> Aircaft on Session Start</TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding CallDeboardOnArrival}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Automatically call Deboard when arrived at the Gate (Brake set, Engines off, Beacon off).&#x0a;GSX will call the Jetway and/or Stairs by itself when Deboarding is requested.">
                    <TextBlock>Call Deboard on <Underline>Arrival</Underline> (after Engines &amp; Beacon off)</TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding RunDepartureDuringDeboarding}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="When the Deboarding Service becomes active, importing a new Flightplan (different OFP ID) will start the Departure Services.&#x0a;The Departure Services will be called as configured - as long as the next Service is not Boarding!&#x0a;The Deboard Service will not be considered as previous Service.">
                    <TextBlock>Start <Underline>Departure</Underline> Services while <Underline>Deboarding</Underline> is active</TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding ChimeOnParked}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Play cabin chime when the aircraft is parked (TaxiIn → Arrival transition).">
                    <TextBlock>Cabin chime on <Underline>Parked</Underline></TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding ChimeOnDeboardComplete}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Play cabin chime when Deboarding completes (Arrival → Turnaround / Departure transition).">
                    <TextBlock>Cabin chime on <Underline>Deboard Complete</Underline></TextBlock>
                </CheckBox>

                <Grid Margin="0,6,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0" Grid.Row="0" Name="GridDepartureServices" Margin="0,0,6,0" MinWidth="384"
                              ToolTip="Departure Services: GSX Services and their Order to be called, monitored or skipped in the Departure Phase.">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Service" MinWidth="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ServiceType}" Margin="4,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Activation" MinWidth="128">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ServiceActivationName}" Margin="5,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Min. Flight Time" MinWidth="112">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="5,0,0,0">
                                            <Label Content="{Binding MinimumFlightDuration, Converter={StaticResource TimeSpanConverter}}" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalAlignment="Center" VerticalContentAlignment="Center" Margin="6,0,0,0" MinWidth="48"/>
                                            <TextBlock Style="{StaticResource TextBlockDefault}" Margin="2,0,0,0">minutes</TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Constraint">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ServiceConstraintName}" MinWidth="96" Margin="6,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Vertical" Margin="0,28,0,0" VerticalAlignment="Top">
                        <Button Name="ButtonUp" Style="{StaticResource BtnSquareSmall}" ToolTip="Move Up Service in the Call Order.">
                            <Image Source="../../Icons/chevron-up.png" Style="{StaticResource ImgSquareSmall}"/>
                        </Button>
                        <Button Name="ButtonDown" Margin="0,6,0,0" Style="{StaticResource BtnSquareSmall}" ToolTip="Move Down Service in the Call Order.">
                            <Image Source="../../Icons/chevron-down.png" Style="{StaticResource ImgSquareSmall}"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="0" Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0"
                                Visibility="{Binding HasSelection, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolVisibilityConverter}}">
                        <TextBlock Name="LabelServiceName" Margin="5,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                        <ComboBox Name="SelectorActivation" ItemsSource="{Binding TextServiceActivations}" SelectedIndex="0" SelectedValuePath="Key" DisplayMemberPath="Value" Style="{StaticResource ComboBoxDefault}"
                                  ToolTip="Select if and how to activate the Service:&#x0a;
                                  Skip / Ignore: Service will neither be called nor monitored by Prosim2GSX&#x0a;
                                  Manual by User: Service will be called externally by the User or another App (but must be completed to end the Departure Phase)&#x0a;
                                  Previous called: Service will directly be called after the previous Service was called&#x0a;
                                  Previous requested: Service will be called as soon as the previous Service is reported as 'requested' by GSX&#x0a;
                                  Previous active: Service will be called as soon as the previous Service is reported as 'active' by GSX&#x0a;
                                  Previous completed: Service will be called as soon as the previous Service is reported as 'completed' by GSX&#x0a;
                                  All completed: Service will only be called after all previous Service are reported as 'completed' by GSX&#x0a;
                                  Note: The first Service will always be called directly (if not set to skipped or manual), as it has no previous Service!"/>
                        <TextBox Name="InputDuration" Margin="8,0,0,0" Style="{StaticResource TextBoxCentered}" ToolTip="Only call/monitor the Service if the scheduled Flight Time is greater than the specified Value."/>
                        <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}" ToolTip="Only call/monitor the Service if the scheduled Flight Time is greater than the specified Value.">minutes</TextBlock>
                        <ComboBox Margin="10,0,0,0" Name="SelectorConstraint" ItemsSource="{Binding TextServiceConstraints}" SelectedIndex="0" SelectedValuePath="Key" DisplayMemberPath="Value" Style="{StaticResource ComboBoxDefault}"
                                  ToolTip="Select a Constraint for calling the Service:&#x0a;
                                  None: No Constraint applied, the Service is called every time (Time Constraint still applies)&#x0a;
                                  Only Departure: The Service is only called on the first Departure (resetted by Prosim2GSX Restart or new Session)&#x0a;
                                  Only Turn: The Service is only called on Turn Arounds (resetted by Prosim2GSX Restart or new Session)&#x0a;
                                  Only on Hub: The Service is only called when the Departure ICAO (as of SimBrief) has a Match in the Company Hub List&#x0a;"/>
                    </StackPanel>

                    <Button Grid.Column="1" Grid.Row="1" Name="ButtonEdit" Margin="0,6,0,0" Style="{StaticResource BtnSquareSmall}"
                            Visibility="{Binding HasSelection, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}, Converter={StaticResource BoolVisibilityConverter}}"
                            ToolTip="Edit Service Activation">
                        <Image Name="ImageEdit" Style="{StaticResource ImgSquareSmall}"/>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- REFUEL -->
        <TextBlock Style="{StaticResource CategoryHeader}" Text="REFUEL" Margin="0,0,0,4"/>
        <Border Style="{StaticResource SectionCardBorder}">
            <StackPanel>
                <StackPanel Style="{StaticResource SettingItemPanel}" ToolTip="Select the Method to be used for Refueling the Aircraft: via Fixed Rate or via Dynamic Rate.">
                    <TextBlock Style="{StaticResource TextBlockDefault}" Margin="0,0,6,0">Refuel Method:</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxDefault}" SelectedValue="{Binding RefuelMethod}" ItemsSource="{Binding RefuelMethodOptions}" SelectedValuePath="Key" DisplayMemberPath="Value"/>
                </StackPanel>

                <StackPanel Style="{StaticResource SettingItemPanel}" Visibility="{Binding RefuelFixedVisible, Converter={StaticResource BoolVisibilityConverter}}"
                            ToolTip="Refuel the Aircraft with a fixed Rate. Refueling Duration is variable (depending on planned Fuel)">
                    <TextBlock Style="{StaticResource TextBlockDefault}">Fixed Refuel Rate:</TextBlock>
                    <TextBox Name="InputRefuelRate" Margin="6,0,0,0" Style="{StaticResource TextBoxCentered}"/>
                    <TextBlock Text="{Binding DisplayUnitCurrentString}" Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                    <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">per sec</TextBlock>
                </StackPanel>

                <StackPanel Style="{StaticResource SettingItemPanel}" Visibility="{Binding RefuelDynamicVisible, Converter={StaticResource BoolVisibilityConverter}}"
                            ToolTip="Refuel the Aircraft with a variable Rate. Refueling Duration is fixed (independent of planned Fuel)">
                    <TextBlock Margin="0,0,6,0" Style="{StaticResource TextBlockDefault}">Use dynamic Rate for fixed <Underline>Time Target</Underline>:</TextBlock>
                    <TextBox Name="InputTimeTarget" Margin="6,0,0,0" Style="{StaticResource TextBoxCentered}"/>
                    <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                </StackPanel>

                <CheckBox IsChecked="{Binding SkipFuelOnTankering}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Do not call and ignore GSX Refuel Service if the Fuel on Board is already equal or higher than the planned Fuel Value.">
                    <TextBlock><Underline>Skip Refuel</Underline> when FOB is higher than planned (for Tankering)</TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding RefuelFinishOnHose}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="When the GSX Fuel Hose is reported as disconnected, stop Refueling and instantly set the planned Fuel">
                    <TextBlock><Underline>Finish Refuel immediately</Underline> when the Fuel Hose disconnects</TextBlock>
                </CheckBox>
            </StackPanel>
        </Border>

        <!-- DE-ICING -->
        <TextBlock Style="{StaticResource CategoryHeader}" Text="DE-ICING" Margin="0,0,0,4"/>
        <Border Style="{StaticResource SectionCardBorder}">
            <StackPanel>
                <CheckBox IsChecked="{Binding AutoDeiceEnabled}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Automatically answer Yes to the GSX de-icing request and select the configured fluid + concentration. When disabled, the de-icing menu is left open for manual selection.">
                    <TextBlock>Automatically respond <Underline>Yes</Underline> to GSX de-icing request</TextBlock>
                </CheckBox>
                <StackPanel Style="{StaticResource SettingItemPanel}" IsEnabled="{Binding AutoDeiceEnabled}"
                            ToolTip="Fluid type and concentration to auto-select after answering Yes. Matched against the GSX de-icing type menu by text (e.g. 'Type IV' + '100').">
                    <TextBlock Style="{StaticResource TextBlockDefault}" Margin="0,0,6,0">Fluid:</TextBlock>
                    <ComboBox Style="{StaticResource ComboBoxDefault}"
                              SelectedValue="{Binding AutoDeiceFluid}"
                              ItemsSource="{Binding AutoDeiceFluidOptions}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Value"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- PUSHBACK & TUG -->
        <TextBlock Style="{StaticResource CategoryHeader}" Text="PUSHBACK &amp; TUG" Margin="0,0,0,4"/>
        <Border Style="{StaticResource SectionCardBorder}">
            <StackPanel>
                <StackPanel Style="{StaticResource SettingItemPanel}" ToolTip="Automatically call Pushback after all Departure Services have finished - in Case the Tug was already attached during Boarding.">
                    <TextBlock Style="{StaticResource TextBlockDefault}">
                        Call for Pushback when <Underline>Tug was attached</Underline> during Boarding:
                    </TextBlock>
                    <ComboBox SelectedValue="{Binding CallPushbackWhenTugAttached}" SelectedValuePath="Tag" Margin="8,0,0,0" Style="{StaticResource ComboBoxDefault}">
                        <ComboBoxItem Tag="0">Never</ComboBoxItem>
                        <ComboBoxItem Tag="1">Services completed</ComboBoxItem>
                        <ComboBoxItem Tag="2">Final transmitted</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <CheckBox IsChecked="{Binding CallPushbackOnBeacon}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Automatically call Pushback when the Beacon is turned on (AND Brake set &amp; Power disconnected). With SequenceOnBeacon enabled, this controls whether pushback is auto-called at the end of the sequence or waits for INT/RAD.">
                    <TextBlock>Call for Pushback when <Underline>Beacon</Underline> is turned on</TextBlock>
                </CheckBox>

                <CheckBox IsChecked="{Binding SequenceOnBeacon}" Style="{StaticResource CheckBoxSettingItem}"
                          ToolTip="Use the beacon-orchestrated departure sequence: beacon on + APU running + Final LS → close doors → retract jetway → disconnect GPU → ready for pushback. Overrides CloseDoorsOnFinal and RemoveJetwayStairsOnFinal when enabled. INT/RAD skips the delay of the current step.">
                    <TextBlock>Use <Underline>Beacon-orchestrated</Underline> departure sequence</TextBlock>
                </CheckBox>

                <Grid Margin="20,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,4,10,4" VerticalAlignment="Center">Doors close delay (s):</TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="0,4,4,4" VerticalAlignment="Center">min</TextBlock>
                    <TextBox  Grid.Row="0" Grid.Column="2" Width="40" Margin="0,4,10,4" Text="{Binding SeqDoorsCloseDelayMin}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Margin="0,4,4,4" VerticalAlignment="Center">max</TextBlock>
                    <TextBox  Grid.Row="0" Grid.Column="4" Width="40" Margin="0,4,0,4" Text="{Binding SeqDoorsCloseDelayMax}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,4,10,4" VerticalAlignment="Center">Jetway retract delay (s):</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4,4,4" VerticalAlignment="Center">min</TextBlock>
                    <TextBox  Grid.Row="1" Grid.Column="2" Width="40" Margin="0,4,10,4" Text="{Binding SeqJetwayRetractDelayMin}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,4,4,4" VerticalAlignment="Center">max</TextBlock>
                    <TextBox  Grid.Row="1" Grid.Column="4" Width="40" Margin="0,4,0,4" Text="{Binding SeqJetwayRetractDelayMax}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,4,10,4" VerticalAlignment="Center">GPU disconnect delay (s):</TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4,4,4" VerticalAlignment="Center">min</TextBlock>
                    <TextBox  Grid.Row="2" Grid.Column="2" Width="40" Margin="0,4,10,4" Text="{Binding SeqGpuDisconnectDelayMin}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Margin="0,4,4,4" VerticalAlignment="Center">max</TextBlock>
                    <TextBox  Grid.Row="2" Grid.Column="4" Width="40" Margin="0,4,0,4" Text="{Binding SeqGpuDisconnectDelayMax}"/>
                </Grid>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
