<UserControl x:Class="Prosim2GSX.UI.Views.Monitor.ViewMonitor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Monitor"
             d:DataContext="{d:DesignInstance Type=local:ModelMonitor}"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,8">

            <!-- SECTION 1: CONNECTION STATUS -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="CONNECTION STATUS"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <WrapPanel HorizontalAlignment="Center">
                    <!-- MSFS -->
                    <StackPanel Orientation="Horizontal" Margin="12,4">
                        <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding SimRunningColor}"/>
                        <Label Margin="4,0,0,0" VerticalAlignment="Center">MSFS</Label>
                    </StackPanel>
                    <!-- SIMCONNECT -->
                    <StackPanel Orientation="Horizontal" Margin="12,4">
                        <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding SimConnectedColor}"/>
                        <Label Margin="4,0,0,0" VerticalAlignment="Center">SIMCONNECT</Label>
                    </StackPanel>
                    <!-- SESSION -->
                    <StackPanel Orientation="Horizontal" Margin="12,4">
                        <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding SimSessionColor}"/>
                        <Label Margin="4,0,0,0" VerticalAlignment="Center">SESSION</Label>
                    </StackPanel>
                    <!-- PROSIM BINARY -->
                    <StackPanel Orientation="Horizontal" Margin="12,4">
                        <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppAircraftBinaryColor}"/>
                        <Label Margin="4,0,0,0" VerticalAlignment="Center">PROSIM BINARY</Label>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- SECTION 2: FLIGHT PHASE -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="FLIGHT PHASE"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <!-- Current phase label -->
                    <Label FontSize="18" FontWeight="Bold"
                           Content="{Binding AppAutomationState}"
                           Foreground="{StaticResource PrimaryColorBrush}"
                           HorizontalAlignment="Center"/>

                    <!-- Phase progress bar -->
                    <UniformGrid Rows="2" Columns="7" Margin="4,4,4,0">
                        <!-- Row 0: Phase indicator blocks -->
                        <!-- PREFLIGHT / SessionStart=0, Preparation=1 -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="SessionStart">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="Preparation">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- DEPARTURE -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="Departure">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- PUSHBACK -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="PushBack">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- TAXI OUT -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="TaxiOut">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- FLIGHT -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="Flight">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- TAXI IN -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="TaxiIn">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                        <!-- ARRIVAL -->
                        <Border Height="14" Margin="2,4,2,0" CornerRadius="3">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FFD3D3D3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="Arrival">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding AppAutomationState}" Value="TurnAround">
                                            <Setter Property="Background" Value="#FF1E90FF"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <!-- Row 1: Phase labels -->
                        <TextBlock Text="PREFLIGHT" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="DEPARTURE" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="PUSHBACK" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="TAXI OUT" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="FLIGHT" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="TAXI IN" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                        <TextBlock Text="ARRIVAL" FontSize="9" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- SECTION 3: GSX STATE -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="GSX STATE"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <!-- Service indicators - Solari board style with dual alternating dots when Active -->
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!-- Jetway -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariJetwayBrushConverter}">
                                        <Binding Path="ServiceJetway"/>
                                        <Binding Path="AppAutomationState"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Jetway</TextBlock>
                        </StackPanel>
                        <!-- Stairs -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariJetwayBrushConverter}">
                                        <Binding Path="ServiceStairs"/>
                                        <Binding Path="AppAutomationState"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Stairs</TextBlock>
                        </StackPanel>
                        <!-- Refueling -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceRefuel"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceRefuel"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Refueling</TextBlock>
                        </StackPanel>
                        <!-- Catering -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceCatering"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceCatering"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Catering</TextBlock>
                        </StackPanel>
                        <!-- Boarding -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceBoarding"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceBoarding"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Boarding</TextBlock>
                        </StackPanel>
                        <!-- Deboarding -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceDeboarding"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceDeboarding"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Deboarding</TextBlock>
                        </StackPanel>
                        <!-- GPU -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding ServiceGpuConnectedColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">GPU</TextBlock>
                        </StackPanel>
                        <!-- Jetway connected -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding ServiceJetwayConnectedColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Jetway Connected</TextBlock>
                        </StackPanel>
                        <!-- Stairs connected -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding ServiceStairsConnectedColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Stairs Connected</TextBlock>
                        </StackPanel>
                        <!-- Cleaning -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceCleaning"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceCleaning"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Cleaning</TextBlock>
                        </StackPanel>
                        <!-- Lavatory -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceLavatory"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceLavatory"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Lavatory</TextBlock>
                        </StackPanel>
                        <!-- Pushback -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariPushbackBrushConverter}">
                                        <Binding Path="ServicePushback"/>
                                        <Binding Path="AppAutomationState"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Pushback</TextBlock>
                        </StackPanel>
                        <!-- Water -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="left">
                                        <Binding Path="ServiceWater"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <Ellipse Width="10" Height="10" Margin="2,0,0,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <MultiBinding Converter="{StaticResource SolariServiceBrushConverter}" ConverterParameter="right">
                                        <Binding Path="ServiceWater"/>
                                        <Binding Path="SolariToggle"/>
                                    </MultiBinding>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Water</TextBlock>
                        </StackPanel>
                    </ItemsControl>

                    <!-- GSX status detail row - 5 across -->
                    <Grid Margin="4,6,4,0" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Menu:" FontSize="11" VerticalAlignment="Center" Margin="0,2,6,2" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="{Binding GsxMenu}" FontSize="11" VerticalAlignment="Center" Margin="0,2,12,2"/>
                        <TextBlock Grid.Column="2" Text="Pax Target:" FontSize="11" VerticalAlignment="Center" Margin="0,2,6,2" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="{Binding GsxPaxTarget}" FontSize="11" VerticalAlignment="Center" Margin="0,2,12,2"/>
                        <TextBlock Grid.Column="4" Text="Pax Total:" FontSize="11" VerticalAlignment="Center" Margin="0,2,6,2" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="5" Text="{Binding GsxPaxTotal}" FontSize="11" VerticalAlignment="Center" Margin="0,2,12,2"/>
                        <TextBlock Grid.Column="6" Text="Cargo:" FontSize="11" VerticalAlignment="Center" Margin="0,2,6,2" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="7" Text="{Binding GsxCargoProgress}" FontSize="11" VerticalAlignment="Center" Margin="0,2,12,2"/>
                        <TextBlock Grid.Column="8" Text="Assigned Gate:" FontSize="11" VerticalAlignment="Center" Margin="0,2,6,2" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="9" Text="{Binding AssignedArrivalGate}" FontSize="11" VerticalAlignment="Center" Margin="0,2,0,2"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECTION 4: APP STATUS -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="APP STATUS"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <!-- GSX Controller -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppGsxControllerColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">GSX Controller</TextBlock>
                        </StackPanel>
                        <!-- Aircraft Interface -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppAircraftInterfaceColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Aircraft Interface</TextBlock>
                        </StackPanel>
                        <!-- Automation -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppAutomationControllerColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Automation</TextBlock>
                        </StackPanel>
                        <!-- Audio -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppAudioControllerColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">Audio</TextBlock>
                        </StackPanel>
                        <!-- ProSim SDK -->
                        <StackPanel Orientation="Horizontal" Width="140" Margin="0,3">
                            <Ellipse Width="14" Height="14" VerticalAlignment="Center" Fill="{Binding AppProsimSdkConnectedColor}"/>
                            <TextBlock Margin="6,0,0,0" VerticalAlignment="Center">ProSim SDK</TextBlock>
                        </StackPanel>
                    </ItemsControl>
                    <!-- Profile, Aircraft, and state info - 3 across -->
                    <Grid Margin="4,4,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profile:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AppProfile}" FontSize="11" VerticalAlignment="Center" Margin="4"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Aircraft:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding AppAircraft}" FontSize="11" VerticalAlignment="Center" Margin="4" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="Departure Services:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="5" Text="{Binding AppAutomationDepartureServices}" FontSize="11" VerticalAlignment="Center" Margin="4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="On Ground:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AppOnGround}" FontSize="11" VerticalAlignment="Center" Margin="4"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Engines Running:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding AppEnginesRunning}" FontSize="11" VerticalAlignment="Center" Margin="4"/>
                        <TextBlock Grid.Row="1" Grid.Column="4" Text="In Motion:" FontSize="11" VerticalAlignment="Center" Margin="4" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="5" Text="{Binding AppInMotion}" FontSize="11" VerticalAlignment="Center" Margin="4"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SECTION 5: LOG MESSAGES -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="LOG MESSAGES"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <ListBox Name="LogListBox"
                             ItemsSource="{Binding MessageLog}"
                             BorderThickness="0"
                             Background="Transparent"
                             MaxHeight="135"
                             FontFamily="Consolas"
                             FontSize="10"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             IsHitTestVisible="False">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Name="ButtonGetLog"
                            Command="{Binding LogDirCommand}"
                            HorizontalAlignment="Right"
                            MinWidth="48" MinHeight="24"
                            Padding="4"
                            Margin="0,6,0,0">
                        Get Log
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
