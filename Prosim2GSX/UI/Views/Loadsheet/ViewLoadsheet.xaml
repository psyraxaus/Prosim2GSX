<UserControl x:Class="Prosim2GSX.UI.Views.Loadsheet.ViewLoadsheet"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Loadsheet"
             d:DataContext="{d:DesignInstance Type=local:ModelLoadsheet}"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,8">

            <!-- Header strip: title + RESEND / RESET buttons -->
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Style="{StaticResource CategoryHeader}" Text="LOADSHEET"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Name="BtnResend" Content="RESEND" Margin="0,0,8,0"
                            Padding="14,6" FontSize="11" FontWeight="SemiBold"
                            Click="OnResendClick"/>
                    <Button Name="BtnReset" Content="RESET" Padding="14,6"
                            FontSize="11" FontWeight="SemiBold"
                            Foreground="#DC4040" Click="OnResetClick"/>
                </StackPanel>
            </Grid>

            <!-- Two cards side by side -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- PRELIM -->
                <Border Grid.Column="0" Style="{StaticResource SectionCardBorder}">
                    <StackPanel Margin="14,12,14,12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PRELIM" FontSize="11"
                                       FontWeight="SemiBold" Foreground="{DynamicResource CategoryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                                    Background="{Binding PrelimStatusBrush}" Opacity="0.2"/>
                            <TextBlock Grid.Column="1" Text="{Binding PrelimStatusText}"
                                       Foreground="{Binding PrelimStatusBrush}" FontSize="10"
                                       FontWeight="Bold" Padding="8,3"/>
                        </Grid>

                        <!-- Empty state -->
                        <TextBlock Text="{Binding PrelimEmptyText}" FontStyle="Italic" FontSize="12"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Visibility="{Binding PrelimEmptyVisibility}"
                                   Padding="0,6,0,6"/>

                        <!-- Data state -->
                        <StackPanel Visibility="{Binding PrelimDataVisibility}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="MacTow"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PrelimMacTowText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace"
                                           Foreground="{Binding PrelimMacTowBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TOW"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PrelimTowText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ident"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PrelimIdentText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Received"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PrelimReceivedText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>
                            </Grid>

                            <!-- MAC% range bar -->
                            <Grid Margin="0,12,0,0" Width="220" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MinMacTowText}"
                                               FontSize="10" FontFamily="Consolas, monospace"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="MAC%" FontSize="10"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MaxMacTowText}"
                                               FontSize="10" FontFamily="Consolas, monospace"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Grid.Row="1" Background="#1F1F1F" CornerRadius="3" Height="6" Margin="0,4,0,0">
                                    <Canvas Width="220" Height="6" ClipToBounds="False">
                                        <Ellipse Width="12" Height="12"
                                                 Canvas.Left="{Binding PrelimRangeMarkerLeft}" Canvas.Top="-3"
                                                 Fill="{Binding PrelimRangeMarkerBrush}"
                                                 Stroke="#1A1A1A" StrokeThickness="2"/>
                                    </Canvas>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- FINAL — same structure as PRELIM, FinalCardBorder* drives
                     the red-border highlight when MacTow is out of envelope. -->
                <Border Grid.Column="2" Style="{StaticResource SectionCardBorder}"
                        BorderBrush="{Binding FinalCardBorderBrush}"
                        BorderThickness="{Binding FinalCardBorderThickness}">
                    <StackPanel Margin="14,12,14,12">
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FINAL" FontSize="11"
                                       FontWeight="SemiBold" Foreground="{DynamicResource CategoryTextBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" CornerRadius="10" Padding="8,3"
                                    Background="{Binding FinalStatusBrush}" Opacity="0.2"/>
                            <TextBlock Grid.Column="1" Text="{Binding FinalStatusText}"
                                       Foreground="{Binding FinalStatusBrush}" FontSize="10"
                                       FontWeight="Bold" Padding="8,3"/>
                        </Grid>

                        <TextBlock Text="{Binding FinalEmptyText}" FontStyle="Italic" FontSize="12"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Visibility="{Binding FinalEmptyVisibility}"
                                   Padding="0,6,0,6"/>

                        <StackPanel Visibility="{Binding FinalDataVisibility}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="MacTow"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FinalMacTowText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace"
                                           Foreground="{Binding FinalMacTowBrush}"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TOW"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FinalTowText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ident"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FinalIdentText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Received"
                                           Foreground="{DynamicResource CategoryTextBrush}" FontSize="11"
                                           Margin="0,2,14,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding FinalReceivedText}"
                                           HorizontalAlignment="Right" FontWeight="Bold" FontSize="14"
                                           FontFamily="Consolas, monospace" Foreground="White"/>
                            </Grid>

                            <Grid Margin="0,12,0,0" Width="220" HorizontalAlignment="Stretch">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding MinMacTowText}"
                                               FontSize="10" FontFamily="Consolas, monospace"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="1" Text="MAC%" FontSize="10"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MaxMacTowText}"
                                               FontSize="10" FontFamily="Consolas, monospace"
                                               Foreground="{DynamicResource CategoryTextBrush}"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Border Grid.Row="1" Background="#1F1F1F" CornerRadius="3" Height="6" Margin="0,4,0,0">
                                    <Canvas Width="220" Height="6" ClipToBounds="False">
                                        <Ellipse Width="12" Height="12"
                                                 Canvas.Left="{Binding FinalRangeMarkerLeft}" Canvas.Top="-3"
                                                 Fill="{Binding FinalRangeMarkerBrush}"
                                                 Stroke="#1A1A1A" StrokeThickness="2"/>
                                    </Canvas>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
