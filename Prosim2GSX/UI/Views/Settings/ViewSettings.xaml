<UserControl x:Class="Prosim2GSX.UI.Views.Settings.ViewSettings"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Settings"
             d:DataContext="{d:DesignInstance Type=local:ModelSettings}"
             mc:Ignorable="d"
             d:DesignHeight="768" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="12,8,12,8">

            <!-- THEME SETTINGS -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="THEME SETTINGS"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox ItemsSource="{Binding Themes}"
                                  SelectedIndex="{Binding SelectedThemeIndex}"
                                  Width="180" VerticalAlignment="Center"/>
                        <Button Content="Refresh Themes"
                                Command="{Binding RefreshThemesCommand}"
                                Background="{DynamicResource SecondaryColor}"
                                Foreground="{DynamicResource HeaderText}"
                                BorderThickness="0"
                                Margin="8,0,0,0" Padding="10,5"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ThemesPath}"
                                   VerticalAlignment="Center"
                                   FontSize="10" Opacity="0.6"
                                   Margin="0,0,8,0"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="340"/>
                        <Button Content="Open Folder"
                                Command="{Binding OpenThemeFolderCommand}"
                                Background="{DynamicResource PrimaryColor}"
                                Foreground="{DynamicResource HeaderText}"
                                BorderThickness="0"
                                Padding="10,5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- GENERAL SETTINGS -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="GENERAL SETTINGS"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Which Source is used to get the Unit used in the UI.">UI Unit Source:</TextBlock>
                    <ComboBox Grid.Column="1" Grid.Row="0" SelectedValue="{Binding DisplayUnitSource}" MinWidth="64" MaxWidth="96" ItemsSource="{Binding DisplayUnitSourceItems}" SelectedValuePath="Key" DisplayMemberPath="Value" Margin="6" Style="{StaticResource ComboBoxDefault}" HorizontalAlignment="Left" ToolTip="Which Source is used to get the Unit used in the UI."/>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="The Unit to used in the UI when no other Unit Source is available.">UI Default Unit:</TextBlock>
                    <ComboBox Grid.Column="1" Grid.Row="1" SelectedValue="{Binding DisplayUnitDefault}" MinWidth="64" MaxWidth="96" ItemsSource="{Binding DisplayUnitDefaultItems}" SelectedValuePath="Key" DisplayMemberPath="Value" Margin="6" Style="{StaticResource ComboBoxDefault}" HorizontalAlignment="Left" ToolTip="The Unit to used in the UI when no other Unit Source is available."/>

                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Open the UI when the App is started.">Open UI on Start:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="2" IsChecked="{Binding OpenAppWindowOnStart}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Open the UI when the App is started."/>

                    <TextBlock Grid.Column="0" Grid.Row="3" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="The Weight per Passenger Bag used in Simbrief to calculate Cargo Weight.">Prosim Bag Weight:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="3" Style="{StaticResource SettingItemPanel}" ToolTip="The Weight per Passenger Bag used in Simbrief to calculate Cargo Weight.">
                        <TextBox Name="InputBagWeight" Style="{StaticResource TextBoxCentered}"/>
                        <TextBlock Text="{Binding DisplayUnitCurrentString}" Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="4" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Default Value to set the Fuel on Board to (when the EFB is resetted or saved Fuel is applied).">FOB Reset Default:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="4" Style="{StaticResource SettingItemPanel}" ToolTip="Default Value to set the Fuel on Board to (when the EFB is resetted or saved Fuel is applied).">
                        <TextBox Name="InputFuelDefault" Style="{StaticResource TextBoxCentered}"/>
                        <TextBlock Text="{Binding DisplayUnitCurrentString}" Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="5" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="The maximum allowed Difference when the Fuel on Board is compared to be equal to a specific Target.">Fuel Compare Variance:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="5" Style="{StaticResource SettingItemPanel}" ToolTip="The maximum allowed Difference when the Fuel on Board is compared to be equal to a specific Target.">
                        <TextBox Name="InputFuelVariance" Style="{StaticResource TextBoxCentered}"/>
                        <TextBlock Text="{Binding DisplayUnitCurrentString}" Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="6" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Round the planned Fuel Value to the next higher 100' Fraction.">Round Fuel to 100's:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="6" IsChecked="{Binding FuelRoundUp100}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Round the planned Fuel Value to the next higher 100' Fraction."/>

                    <TextBlock Grid.Column="0" Grid.Row="7" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="If and when the Cabin Ding Sound should be played to announce certain Situations.">Play Cabin Ding Sound:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="7" Style="{StaticResource SettingItemPanel}" Margin="0,6,6,6" ToolTip="If and when the Cabin Ding Sound should be played to announce certain Situations.">
                        <CheckBox IsChecked="{Binding DingOnStartup}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Play the Sound when Reposition was executed and Jetway/Stairs are connected or connecting.">Ding on Startup</CheckBox>
                        <CheckBox IsChecked="{Binding DingOnFinal}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Play the Sound when the Final Loadsheet was transmitted.">Ding on Final LS</CheckBox>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="8" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Enable the animated split-flap character cycling effect in the header bar displays.">Solari Animation:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="8" IsChecked="{Binding SolariAnimationEnabled}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Enable the animated split-flap character cycling effect in the header bar displays."/>

                    <TextBlock Grid.Column="0" Grid.Row="9" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Use SayIntentions.AI for ATIS/weather and gate assignment. Requires SayIntentions installed and api_key in flight.json.">Use SayIntentions:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="9" IsChecked="{Binding UseSayIntentions}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Use SayIntentions.AI for ATIS/weather and gate assignment. Requires SayIntentions installed and api_key in flight.json."/>
                </Grid>
            </Border>

            <!-- TIMING & DELAYS -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="TIMING &amp; DELAYS"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Percent of Cargo Weight per Second applied to the Aircraft after a GSX Value Change.">Cargo Change Rate:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="0" Style="{StaticResource SettingItemPanel}" ToolTip="Percent of Cargo Weight per Second applied to the Aircraft after a GSX Value Change.">
                        <TextBox Name="InputCargoRate" Style="{StaticResource TextBoxCentered}"/>
                        <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">% / s</TextBlock>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6" Style="{StaticResource TextBlockDefault}">Cargo Door Delay:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal" ToolTip="Delay in Seconds to open both Cargo Doors after GSX Boarding became active.">
                            <TextBlock Margin="0,0,6,0" Style="{StaticResource TextBlockDefault}">Open:</TextBlock>
                            <TextBox Name="InputDoorCargoOpenDelay" Style="{StaticResource TextBoxCentered}"/>
                            <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemPanel}" ToolTip="Delay in Seconds to close a Cargo Door when the Loader is finished.">
                            <TextBlock Margin="12,0,6,0" Style="{StaticResource TextBlockDefault}">Close:</TextBlock>
                            <TextBox Name="InputDoorCargoCloseDelay" Style="{StaticResource TextBoxCentered}"/>
                            <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="6" Style="{StaticResource TextBlockDefault}">Refuel Door Delay:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal" ToolTip="Delay in Seconds to open &amp; Power on the Refuel Panel after GSX Refuel became active.">
                            <TextBlock Margin="0,0,6,0" Style="{StaticResource TextBlockDefault}">Open:</TextBlock>
                            <TextBox Name="InputRefuelOpenDelay" Style="{StaticResource TextBoxCentered}"/>
                            <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                        </StackPanel>
                        <StackPanel Style="{StaticResource SettingItemPanel}" ToolTip="Delay in Seconds to close &amp; Power off the Refuel Panel after the Refuel Process has finished.">
                            <TextBlock Margin="12,0,6,0" Style="{StaticResource TextBlockDefault}">Close:</TextBlock>
                            <TextBox Name="InputRefuelCloseDelay" Style="{StaticResource TextBoxCentered}"/>
                            <TextBlock Margin="2,0,0,0" Style="{StaticResource TextBlockDefault}">s</TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- GSX BEHAVIOUR -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="GSX BEHAVIOUR"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Reset the GSX Service State Variables to 1 (callable) when switching to the Flight Phase.">Reset GSX Vars in Flight:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="0" IsChecked="{Binding ResetGsxStateVarsFlight}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Reset the GSX Service State Variables to 1 (callable) when switching to the Flight Phase."/>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Restart the GSX Binary on Taxi-In (~after Touchdown) to ensure a 'clean' State.">Restart GSX on Taxi-In:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="1" IsChecked="{Binding RestartGsxOnTaxiIn}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Restart the GSX Binary on Taxi-In (~after Touchdown) to ensure a 'clean' State."/>

                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Restart the GSX Binary on Startup when the Menu doesn't open / become ready.">Restart GSX on Startup:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Margin="6,0,0,0">
                        <CheckBox IsChecked="{Binding RestartGsxStartupFail}" Style="{StaticResource CheckBoxDefault}" ToolTip="Restart the GSX Binary on Startup when the Menu doesn't open / become ready after a certain Amount of failed Attempts."/>
                        <TextBlock Margin="12,-1,6,0" Style="{StaticResource TextBlockDefault}">Max Failures:</TextBlock>
                        <TextBox Name="InputGsxMaxFail" Style="{StaticResource TextBoxCentered}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="3" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Enable / Disable the core GSX Controller of the App.">Run GSX Controller:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="3" IsChecked="{Binding RunGsxService}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Enable / Disable the core GSX Controller of the App."/>

                    <TextBlock Grid.Column="0" Grid.Row="4" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Enable / Disable the Audio Controller for App Volume Control.">Run Audio Controller:</TextBlock>
                    <CheckBox Grid.Column="1" Grid.Row="4" IsChecked="{Binding RunAudioService}" Style="{StaticResource CheckBoxSettingItem}" ToolTip="Enable / Disable the Audio Controller for App Volume Control."/>
                </Grid>
            </Border>

            <!-- PROSIM SDK & DATA -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="PROSIM SDK &amp; DATA"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Grid.Row="0" Margin="6" Style="{StaticResource TextBlockDefault}" ToolTip="Path to the ProSim SDK DLL file required for ProSim integration.">ProSim SDK Path:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="0" Style="{StaticResource SettingItemPanel}" Orientation="Horizontal" ToolTip="Path to the ProSim SDK DLL file required for ProSim integration.">
                        <TextBox Name="InputProSimSdkPath" Style="{StaticResource TextBoxLeft}" MinWidth="200" MaxWidth="350" Text="{Binding ProSimSdkPath}" IsReadOnly="True"/>
                        <Button Name="ButtonBrowseProSimSdk" Margin="6,0,0,0" Style="{StaticResource BtnSquareSmall}" ToolTip="Browse for ProSim SDK file" Click="ButtonBrowseProSimSdk_Click">
                            <Image Source="../../Icons/cursor.png" Style="{StaticResource ImgSquareSmall}"/>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="6" Style="{StaticResource TextBlockDefault}" VerticalAlignment="Top" ToolTip="The Fuel-on-Board Values currently stored by Prosim2GSX for the various Aircrafts.">Saved Fuel Values:</TextBlock>
                    <StackPanel Grid.Column="1" Grid.Row="1" Margin="6" Orientation="Horizontal">
                        <ListView MinWidth="228" MaxWidth="384" Height="96" MaxHeight="142"
                                  ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  HorizontalAlignment="Left" HorizontalContentAlignment="Left"
                                  VerticalAlignment="Top" VerticalContentAlignment="Center"
                                  Name="ListSavedFuel"/>
                        <Button Name="ButtonRemove" Margin="6,0,6,0" Style="{StaticResource BtnSquareSmall}" VerticalAlignment="Top" ToolTip="Remove selected Entry">
                            <Image Source="../../Icons/remove.png" Style="{StaticResource ImgSquareSmall}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
