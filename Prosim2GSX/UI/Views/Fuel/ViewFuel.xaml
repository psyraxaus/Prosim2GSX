<UserControl x:Class="Prosim2GSX.UI.Views.Fuel.ViewFuel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Fuel"
             d:DataContext="{d:DesignInstance Type=local:ModelFuel}"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="720">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="720" HorizontalAlignment="Center" Margin="12,8,12,8">

            <!-- ── FUEL SUMMARY ─────────────────────────────────────────── -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="FUEL SUMMARY"
                       Margin="0,0,0,4"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel Margin="14,12,14,12">
                    <TextBlock Text="{Binding CapacityHeaderText}" FontSize="11"
                               Foreground="{DynamicResource CategoryTextBrush}"
                               Margin="0,0,0,8"/>

                    <!-- Capacity bar: ProgressBar with overlaid centred label.
                         Foreground drives the colour banding (green/amber/
                         red/neutral); Value is the in-tanks / capacity ratio
                         scaled to 0..100. -->
                    <Grid Height="22">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding CapacityRatioPercent, Mode=OneWay}"
                                     Foreground="{Binding CapacityFillBrush}"
                                     Background="#1F1F1F"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"/>
                        <TextBlock Text="{Binding CapacityLabelText}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas, monospace"
                                   Foreground="White"/>
                    </Grid>

                    <!-- Summary grid: PLANNED vs IN TANKS in KG and L. -->
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- KG row -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="PLANNED (KG)"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="IN TANKS (KG)"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding PlannedKgText}"
                                   FontSize="18" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ContentText}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding InTanksKgText}"
                                   FontSize="18" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ContentText}"
                                   Margin="0,0,0,8"/>

                        <!-- Litres row -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="PLANNED (L)"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="IN TANKS (L)"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   Margin="0,0,0,2"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding PlannedLitresText}"
                                   FontSize="18" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ContentText}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding InTanksLitresText}"
                                   FontSize="18" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource ContentText}"/>
                    </Grid>

                    <!-- Delta row -->
                    <Border Margin="0,12,0,0" Padding="10,6"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="#0DFFFFFF" CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DELTA:" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource CategoryTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding DeltaValueText}"
                                       FontSize="18" FontWeight="Bold"
                                       FontFamily="Consolas, monospace"
                                       Foreground="{Binding DeltaValueBrush}"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="3" Padding="8,2" CornerRadius="3"
                                    Background="#66000000"
                                    Visibility="{Binding DeltaTagVisibility}">
                                <TextBlock Text="{Binding DeltaTagText}" FontSize="10"
                                           FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── TANK BREAKDOWN ──────────────────────────────────────── -->
            <TextBlock Style="{StaticResource CategoryHeader}" Text="TANK BREAKDOWN"
                       Margin="0,14,0,4"/>
            <Border Style="{StaticResource SectionCardBorder}">
                <StackPanel Margin="14,12,14,12">

                    <!-- CENTRE -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CENTRE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Height="12" Minimum="0" Maximum="100"
                                     Value="{Binding CentreFillPercent, Mode=OneWay}"
                                     Foreground="#4CAF50" Background="#1F1F1F"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding CentreLabelText}"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   Foreground="{DynamicResource ContentText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- LEFT -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="LEFT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Height="12" Minimum="0" Maximum="100"
                                     Value="{Binding LeftFillPercent, Mode=OneWay}"
                                     Foreground="#4CAF50" Background="#1F1F1F"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding LeftLabelText}"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   Foreground="{DynamicResource ContentText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- RIGHT -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="RIGHT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource CategoryTextBrush}"
                                   VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Height="12" Minimum="0" Maximum="100"
                                     Value="{Binding RightFillPercent, Mode=OneWay}"
                                     Foreground="#4CAF50" Background="#1F1F1F"
                                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                     VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding RightLabelText}"
                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas, monospace"
                                   Foreground="{DynamicResource ContentText}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="NOTE: THE ABOVE FIGURES ARE LIVE." FontStyle="Italic" FontSize="11"
                       Foreground="{DynamicResource CategoryTextBrush}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
