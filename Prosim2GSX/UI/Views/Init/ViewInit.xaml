<UserControl x:Class="Prosim2GSX.UI.Views.Init.ViewInit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.Init"
             d:DataContext="{d:DesignInstance Type=local:ModelInit}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="#0A0E1A">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- FMS palette + base text style. Self-contained so the WPF look
             doesn't depend on the global theme. -->
        <SolidColorBrush x:Key="FmsBg"        Color="#0A0E1A"/>
        <SolidColorBrush x:Key="FmsBgSection" Color="#0D1220"/>
        <SolidColorBrush x:Key="FmsCyan"      Color="#00D4E8"/>
        <SolidColorBrush x:Key="FmsGreen"     Color="#39FF6E"/>
        <SolidColorBrush x:Key="FmsAmber"     Color="#FFAA00"/>
        <SolidColorBrush x:Key="FmsWhite"     Color="#D8DCE8"/>
        <SolidColorBrush x:Key="FmsGrey"      Color="#4A5268"/>
        <SolidColorBrush x:Key="FmsBtnBg"     Color="#1E2535"/>
        <SolidColorBrush x:Key="FmsBtnBorder" Color="#3A4558"/>
        <SolidColorBrush x:Key="FmsWarn"      Color="#FF4444"/>

        <FontFamily x:Key="FmsFont">Consolas, Lucida Console, Courier New</FontFamily>

        <Style x:Key="FmsLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FmsFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource FmsWhite}"/>
        </Style>

        <Style x:Key="FmsValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FmsFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource FmsGreen}"/>
        </Style>

        <Style x:Key="FmsCyanLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource FmsFont}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource FmsCyan}"/>
        </Style>

        <!-- Sharp-cornered FMS button. Tints to cyan on hover; primary
             variant gets cyan border by default; destructive gets red. -->
        <Style x:Key="FmsBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="{StaticResource FmsFont}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{StaticResource FmsBtnBg}"/>
            <Setter Property="Foreground" Value="{StaticResource FmsWhite}"/>
            <Setter Property="BorderBrush" Value="{StaticResource FmsBtnBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FmsCyan}"/>
                                <Setter Property="Foreground" Value="{StaticResource FmsCyan}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FmsBtnPrimary" TargetType="Button" BasedOn="{StaticResource FmsBtn}">
            <Setter Property="BorderBrush" Value="{StaticResource FmsCyan}"/>
            <Setter Property="Foreground" Value="{StaticResource FmsCyan}"/>
        </Style>

        <Style x:Key="FmsBtnAmber" TargetType="Button" BasedOn="{StaticResource FmsBtn}">
            <Setter Property="BorderBrush" Value="{StaticResource FmsAmber}"/>
            <Setter Property="Foreground" Value="{StaticResource FmsAmber}"/>
        </Style>

        <Style x:Key="FmsBtnWarn" TargetType="Button" BasedOn="{StaticResource FmsBtn}">
            <Setter Property="BorderBrush" Value="{StaticResource FmsWarn}"/>
            <Setter Property="Foreground" Value="{StaticResource FmsWarn}"/>
        </Style>

        <Style x:Key="FmsSeparator" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource FmsGrey}"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
        </Style>

        <!-- BoolToVisibility — used to show/hide the override-active fields. -->
        <Style x:Key="FmsRowGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer Background="{StaticResource FmsBg}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="14,12,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── LEFT COLUMN — ACTIVE / INIT ────────────────────────── -->
            <Border Grid.Column="0" Grid.Row="0"
                    Background="{StaticResource FmsBgSection}"
                    BorderBrush="{StaticResource FmsGrey}" BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Style="{StaticResource FmsCyanLabel}" Text="ACTIVE / INIT"/>
                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- FLT NBR + STATUS -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FLT NBR"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}" Text="{Binding FlightNumberText}"/>
                    </Grid>

                    <!-- FROM / TO / ALTN -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FROM"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}" Text="{Binding DepartureText}"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource FmsLabel}" Text="TO"/>
                        <TextBlock Grid.Column="3" Style="{StaticResource FmsValue}" Text="{Binding ArrivalText}"/>
                        <TextBlock Grid.Column="4" Style="{StaticResource FmsLabel}" Text="ALTN"/>
                        <TextBlock Grid.Column="5" Style="{StaticResource FmsValue}" Text="{Binding AlternateText}"/>
                    </Grid>

                    <!-- RWY / CALLSIGN -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="RWY OUT/IN"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}">
                            <Run Text="{Binding DepartureRwyText}"/><Run Text=" / "/><Run Text="{Binding ArrivalRwyText}"/>
                        </TextBlock>
                        <TextBlock Grid.Column="2" Style="{StaticResource FmsLabel}" Text="CALLSIGN"/>
                        <TextBlock Grid.Column="3" Style="{StaticResource FmsValue}" Text="{Binding CallsignText}"/>
                    </Grid>

                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- CRZ FL / CI -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="CRZ FL"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}" Text="{Binding CruiseFlText}"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource FmsLabel}" Text="CI"/>
                        <TextBlock Grid.Column="3" Style="{StaticResource FmsValue}" Text="{Binding CostIndexText}"/>
                    </Grid>

                    <!-- ROUTE -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="CPNY RTE"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding RouteText}" TextWrapping="Wrap"/>
                    </Grid>

                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- STD / ETA -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="STD"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}" Text="{Binding StdText}"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource FmsLabel}" Text="ETA"/>
                        <TextBlock Grid.Column="3" Style="{StaticResource FmsValue}" Text="{Binding EtaText}"/>
                    </Grid>

                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- STATUS -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Rectangle Grid.Column="0" Width="8" Height="8" HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Fill="{Binding StatusBrush}"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding StatusText}"
                                   Foreground="{Binding StatusBrush}"/>
                        <TextBlock Grid.Column="2" Style="{StaticResource FmsLabel}"
                                   Text="{Binding SourceText}"/>
                    </Grid>

                    <TextBlock Style="{StaticResource FmsLabel}"
                               Foreground="{StaticResource FmsWarn}"
                               Text="{Binding LastFetchError}"
                               TextWrapping="Wrap"
                               Visibility="{Binding HasFetchError, Converter={StaticResource BoolToVis}}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- ─── RIGHT COLUMN — DATA / STATUS ───────────────────────── -->
            <Border Grid.Column="2" Grid.Row="0"
                    Background="{StaticResource FmsBgSection}"
                    BorderBrush="{StaticResource FmsGrey}" BorderThickness="1"
                    Padding="14">
                <StackPanel>
                    <TextBlock Style="{StaticResource FmsCyanLabel}" Text="DATA / STATUS"/>
                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- ACFT -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="ACFT"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding AircraftTypeText}" TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="REG"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}" Text="{Binding AircraftRegText}"/>
                    </Grid>

                    <Border Style="{StaticResource FmsSeparator}"/>

                    <!-- WEIGHTS / FUEL — left-label, right-value pairs -->
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="ZFW"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding ZfwText}" Foreground="{Binding ZfwBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="OEW"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding OewText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FUEL RAMP"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding FuelRampText}" Foreground="{Binding FuelRampBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FUEL TRIP"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding FuelTripText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FUEL MIN"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding FuelMinText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="FUEL EXTRA"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding FuelExtraText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="PAX"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding PaxText}" Foreground="{Binding PaxBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Style="{StaticResource FmsRowGrid}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Style="{StaticResource FmsLabel}" Text="CARGO"/>
                        <TextBlock Grid.Column="1" Style="{StaticResource FmsValue}"
                                   Text="{Binding CargoText}" Foreground="{Binding CargoBrush}"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Border Style="{StaticResource FmsSeparator}"/>

                    <TextBlock Style="{StaticResource FmsLabel}"
                               Text="{Binding FetchedAtText}"
                               Foreground="{StaticResource FmsGrey}"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- ─── ACTION BAR — bottom row spanning both columns ──────── -->
            <Grid Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" Margin="0,12,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource FmsBtnPrimary}"
                            Content="FETCH OFP"
                            Click="OnFetchOfpClick"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource FmsBtnPrimary}"
                            Content="SYNC TO FMS"
                            Click="OnSyncToFmsClick"
                            IsEnabled="{Binding SyncEnabled}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource FmsBtnAmber}"
                            Content="CLEAR OVERRIDES"
                            Click="OnClearOverridesClick"
                            IsEnabled="{Binding ClearOverridesEnabled}"
                            Margin="0,0,8,0"/>
                    <Button Style="{StaticResource FmsBtnWarn}"
                            Content="RESET FLIGHT"
                            Click="OnResetFlightClick"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
