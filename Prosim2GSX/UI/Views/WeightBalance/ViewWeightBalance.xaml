<UserControl x:Class="Prosim2GSX.UI.Views.WeightBalance.ViewWeightBalance"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI.Views.WeightBalance"
             d:DataContext="{d:DesignInstance Type=local:ModelWeightBalance}"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../../StyleResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <local:NegativeHalfConverter x:Key="NegHalf"/>

            <!-- Shared item-container styles. Both bind to the same item
                 properties (CenterLeft/CenterTop for labels, Left/Top for
                 ticks) so each ItemsControl just plugs the right style in. -->
            <Style x:Key="LabelContainerStyle" TargetType="ContentPresenter">
                <Setter Property="Canvas.Left" Value="{Binding CenterLeft}"/>
                <Setter Property="Canvas.Top"  Value="{Binding CenterTop}"/>
            </Style>
            <Style x:Key="TickContainerStyle" TargetType="ContentPresenter">
                <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                <Setter Property="Canvas.Top"  Value="{Binding Top}"/>
            </Style>

            <!-- Plain axis label. The wrapper Canvas is 0×0 but Canvas
                 doesn't clip its children or constrain their measure, so
                 the TextBlock sizes naturally. Setting Canvas.Left/Top to
                 -ActualWidth/2 / -ActualHeight/2 centres the text on the
                 wrapper's origin — which the ContentPresenter has already
                 placed at (CenterLeft, CenterTop). RenderTransformOrigin
                 then scales / rotates around the same centre. -->
            <DataTemplate x:Key="AxisLabelTemplate" DataType="{x:Type local:ChartLabel}">
                <Canvas>
                    <TextBlock x:Name="lbl" Text="{Binding Text}"
                               Foreground="#FFFFFF" FontSize="14"
                               Canvas.Left="{Binding ActualWidth,  ElementName=lbl, Converter={StaticResource NegHalf}}"
                               Canvas.Top ="{Binding ActualHeight, ElementName=lbl, Converter={StaticResource NegHalf}}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                                <RotateTransform Angle="{Binding Angle}"/>
                            </TransformGroup>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </Canvas>
            </DataTemplate>

            <!-- Pill-bordered annotation. Same centring trick; the Border
                 carries the dark translucent fill that sits behind the
                 limit lines and envelope-edge labels in the source chart. -->
            <DataTemplate x:Key="AnnotationTemplate" DataType="{x:Type local:ChartLabel}">
                <Canvas>
                    <Border x:Name="brd" Background="#B33A3D3B" Padding="3,1,3,1"
                            Canvas.Left="{Binding ActualWidth,  ElementName=brd, Converter={StaticResource NegHalf}}"
                            Canvas.Top ="{Binding ActualHeight, ElementName=brd, Converter={StaticResource NegHalf}}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
                                <RotateTransform Angle="{Binding Angle}"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <TextBlock Text="{Binding Text}" Foreground="#FFFFFF" FontSize="14"/>
                    </Border>
                </Canvas>
            </DataTemplate>

            <!-- Y-axis tick. Width comes from the item (10 long, 5 short);
                 the container places the rectangle so its right edge sits
                 just inside the chart frame at the matching weight value. -->
            <DataTemplate x:Key="TickTemplate" DataType="{x:Type local:ChartTick}">
                <Rectangle Width="{Binding Width}" Height="1" Fill="#FFFFFF"/>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="510"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: CG envelope chart -->
            <StackPanel Grid.Column="0">
                <TextBlock Style="{StaticResource CategoryHeader}" Text="CG ENVELOPE"/>
                <Border Style="{StaticResource SectionCardBorder}">
                    <!-- Viewbox lets the fixed-size 600×580 chart Canvas
                         scale uniformly to the column's available width.
                         StretchDirection="DownOnly" prevents up-scaling
                         past the native 600 px (so the labels stay crisp
                         on huge windows). -->
                    <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Left">
                        <Canvas Width="600" Height="580" Background="#1A1A1A">

                            <!-- Envelope graphic. Fills the chart sub-rectangle;
                                 every label and dot below is positioned in the
                                 same coordinate system. -->
                            <Image Source="/Prosim2GSX;component/UI/Views/WeightBalance/Resources/wandb.png"
                                   Canvas.Left="80" Canvas.Top="30"
                                   Width="500" Height="435" Stretch="Fill"/>

                            <!-- X-axis %MAC labels (top of chart). -->
                            <ItemsControl ItemsSource="{Binding XAxisLabels}"
                                          Width="600" Height="580"
                                          ItemTemplate="{StaticResource AxisLabelTemplate}"
                                          ItemContainerStyle="{StaticResource LabelContainerStyle}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Y-axis weight labels (left side). -->
                            <ItemsControl ItemsSource="{Binding YAxisLabels}"
                                          Width="600" Height="580"
                                          ItemTemplate="{StaticResource AxisLabelTemplate}"
                                          ItemContainerStyle="{StaticResource LabelContainerStyle}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Y-axis tick marks (1T resolution). -->
                            <ItemsControl ItemsSource="{Binding Ticks}"
                                          Width="600" Height="580"
                                          ItemTemplate="{StaticResource TickTemplate}"
                                          ItemContainerStyle="{StaticResource TickContainerStyle}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Limit-line annotations (MTOW / MLW / MZFW). -->
                            <ItemsControl ItemsSource="{Binding LimitAnnotations}"
                                          Width="600" Height="580"
                                          ItemTemplate="{StaticResource AnnotationTemplate}"
                                          ItemContainerStyle="{StaticResource LabelContainerStyle}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- Envelope-edge annotations (Operational Limits +
                                 Take-Off / Zfw labels with their rotations). -->
                            <ItemsControl ItemsSource="{Binding EnvelopeAnnotations}"
                                          Width="600" Height="580"
                                          ItemTemplate="{StaticResource AnnotationTemplate}"
                                          ItemContainerStyle="{StaticResource LabelContainerStyle}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>

                            <!-- ZFW point — pink quadrant-fill crosshair.
                                 Two pie wedges (top-right + bottom-left) painted
                                 in pink over a white base; crosshair lines
                                 extend slightly past the rim. -->
                            <Grid Width="22" Height="22"
                                  Canvas.Left="{Binding ZfwDotLeft}"
                                  Canvas.Top="{Binding ZfwDotTop}"
                                  Visibility="{Binding ZfwDotVisibility}">
                                <Ellipse Fill="White" Stroke="#80000000" StrokeThickness="1"/>
                                <Path Fill="#E91E63">
                                    <Path.Data>
                                        <GeometryGroup>
                                            <PathGeometry>
                                                <PathFigure StartPoint="11,11" IsClosed="True">
                                                    <LineSegment Point="11,1"/>
                                                    <ArcSegment Point="21,11" Size="10,10" SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                            <PathGeometry>
                                                <PathFigure StartPoint="11,11" IsClosed="True">
                                                    <LineSegment Point="11,21"/>
                                                    <ArcSegment Point="1,11" Size="10,10" SweepDirection="Clockwise"/>
                                                </PathFigure>
                                            </PathGeometry>
                                        </GeometryGroup>
                                    </Path.Data>
                                </Path>
                                <Line X1="11" Y1="-2" X2="11" Y2="24" Stroke="White" StrokeThickness="1.2"/>
                                <Line X1="-2" Y1="11" X2="24" Y2="11" Stroke="White" StrokeThickness="1.2"/>
                            </Grid>

                            <!-- GW point — solid light blue with white crosshair. -->
                            <Grid Width="22" Height="22"
                                  Canvas.Left="{Binding GwDotLeft}"
                                  Canvas.Top="{Binding GwDotTop}"
                                  Visibility="{Binding GwDotVisibility}">
                                <Ellipse Fill="#80B7CFD9" Stroke="#FFFFFF" StrokeThickness="1"/>
                                <Line X1="11" Y1="-2" X2="11" Y2="24" Stroke="White" StrokeThickness="1.2"/>
                                <Line X1="-2" Y1="11" X2="24" Y2="11" Stroke="White" StrokeThickness="1.2"/>
                            </Grid>

                            <!-- MAC% gauge bars below the chart. The track
                                 is invisible; only the live coloured fill
                                 renders so an empty bar is invisible rather
                                 than appearing as a dark band. -->
                            <Rectangle Canvas.Left="80" Canvas.Top="470" Height="5"
                                       Width="{Binding ZfwBarFillWidth}" Fill="#E91E63"/>
                            <Rectangle Canvas.Left="80" Canvas.Top="478" Height="5"
                                       Width="{Binding GwBarFillWidth}" Fill="#FF8A00"/>

                            <!-- Bordered summary strip — 4 cells in a row. -->
                            <Grid Canvas.Left="80" Canvas.Top="495" Width="500" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#3F3F3F" BorderThickness="1" Padding="6,4,6,4">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Foreground="#CFD5E6" FontSize="10"
                                                   HorizontalAlignment="Center" Text="ZFW (KG)"/>
                                        <TextBlock Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding ZfwKg, StringFormat={}{0:N0}}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" BorderBrush="#3F3F3F" BorderThickness="0,1,1,1" Padding="6,4,6,4">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Foreground="#CFD5E6" FontSize="10"
                                                   HorizontalAlignment="Center" Text="MACZFW (%)"/>
                                        <TextBlock Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding MaczfwPercent, StringFormat={}{0:F1}}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" BorderBrush="#3F3F3F" BorderThickness="0,1,1,1" Padding="6,4,6,4">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Foreground="#CFD5E6" FontSize="10"
                                                   HorizontalAlignment="Center" Text="GW (KG)"/>
                                        <TextBlock Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding GwKg, StringFormat={}{0:N0}}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" BorderBrush="#3F3F3F" BorderThickness="0,1,1,1" Padding="6,4,6,4">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Foreground="#CFD5E6" FontSize="10"
                                                   HorizontalAlignment="Center" Text="MACGW (%)"/>
                                        <TextBlock Foreground="#FFFFFF" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding MacgwPercent, StringFormat={}{0:F1}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Live-data note. Centred over the gauge/summary
                                 width so it visually anchors on the chart. -->
                            <TextBlock Canvas.Left="80" Canvas.Top="558" Width="500"
                                       FontStyle="Italic" FontSize="11"
                                       TextAlignment="Center" Foreground="#CFD5E6"
                                       Text="NOTE: THE ABOVE FIGURES ARE LIVE."/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <!-- MACTOW row — sits below the chart card. Colour swaps to
                     red when the resolved MACTOW falls outside MinMacTow /
                     MaxMacTow; the VALID RANGE line only renders in that
                     case. The summary strip inside the chart canvas stays
                     focused on live values; this row centralises the
                     MACTOW envelope check + sync action. -->
                <Border Style="{StaticResource SectionCardBorder}" Margin="0,6,0,0" Padding="8,6,8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- "MACTOW (%): nn.n" — green if in range, red if not. -->
                        <StackPanel Grid.Column="0" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="MACTOW (%):" Foreground="{DynamicResource CategoryTextBrush}"
                                       FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Margin="6,0,0,0" FontWeight="Bold" FontSize="14"
                                       VerticalAlignment="Center"
                                       Foreground="{Binding MacTowBrush}"
                                       Text="{Binding MactowPercent, StringFormat={}{0:F1}}"/>
                            <!-- Warning triangle when out of range. -->
                            <TextBlock Margin="8,0,0,0" FontSize="14" FontWeight="Bold"
                                       VerticalAlignment="Center" Text="&#x26A0;"
                                       Foreground="#E53935"
                                       Visibility="{Binding MacTowErrorRangeVisibility}"/>
                            <!-- Resolution-source chip (FINAL / PRELIM / COMPUTED). -->
                            <Border Margin="10,0,0,0" Padding="6,2,6,2" CornerRadius="3"
                                    Background="{Binding MacTowSourceBrush}"
                                    ToolTip="{Binding MacTowSourceTooltip}">
                                <TextBlock Text="{Binding MacTowSourceText}"
                                           Foreground="#FFFFFF"
                                           FontSize="10" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- VALID RANGE line — only shown on error. -->
                        <TextBlock Grid.Column="0" Grid.Row="1" Margin="0,2,0,0"
                                   FontSize="11" Foreground="#E53935"
                                   Text="{Binding MacTowRangeText}"
                                   Visibility="{Binding MacTowErrorRangeVisibility}"/>

                        <!-- "FMS OUT OF DATE — last sync HH:MM:SS (PRELIM)"
                             — only shown when the last-synced values have
                             drifted past operational thresholds. -->
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3"
                                   Margin="0,4,0,0" FontSize="11" FontWeight="Bold"
                                   Foreground="#F5A623"
                                   Text="{Binding FmsSyncStaleText}"
                                   Visibility="{Binding FmsSyncStaleVisibility}"/>

                        <!-- SYNC TO FMS button. Disabled while syncing or
                             when MACTOW is out of range. Background flashes
                             green/red after the attempt; FmsSyncMessage is
                             the trailing status text. -->
                        <Button Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                MinWidth="140" Padding="12,6,12,6" Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Background="{Binding FmsSyncFlashBrush}"
                                IsEnabled="{Binding IsSyncEnabled}"
                                Command="{Binding SyncToFmsCommand}"
                                ToolTip="MACTOW out of range">
                            <TextBlock Text="{Binding SyncButtonText}" FontWeight="Bold"/>
                        </Button>

                        <!-- Status message under the button row. -->
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="2"
                                   Margin="0,4,0,0" FontSize="11"
                                   Foreground="{Binding FmsSyncFlashBrush}"
                                   Text="{Binding FmsSyncMessage}"
                                   Visibility="{Binding FmsSyncMessageVisibility}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- RIGHT: data panels.
                 Grid.IsSharedSizeScope keeps the first ("Pax/Cargo/FWD-AFT/Fuel")
                 label column the same width across the three sub-grids, so rows
                 line up while still auto-sizing to the widest label. -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0" Grid.IsSharedSizeScope="True">

                <!-- PASSENGERS -->
                <TextBlock Style="{StaticResource CategoryHeader}" Text="PASSENGERS"/>
                <Border Style="{StaticResource SectionCardBorder}">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="WbLabelCol"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" TextWrapping="Wrap"
                                   Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">
                            <Run Text="CAPACITY: "/>
                            <Run Text="{Binding PassengersTotalCapacity, Mode=OneWay}"/>
                            <Run Text=" ECONOMY"/>
                        </TextBlock>

                        <Label Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource CategoryTextBrush}">PLANNED</Label>
                        <Label Grid.Row="1" Grid.Column="2" Foreground="{DynamicResource CategoryTextBrush}">BOARDED</Label>

                        <Label Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">Pax</Label>
                        <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding PassengersPlanned}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding PassengersBoarded}"/>
                    </Grid>
                </Border>

                <!-- CARGO -->
                <TextBlock Style="{StaticResource CategoryHeader}" Text="CARGO" Margin="0,8,0,0"/>
                <Border Style="{StaticResource SectionCardBorder}">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="WbLabelCol"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" TextWrapping="Wrap"
                                   Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">
                            <Run Text="CAPACITY: "/>
                            <Run Text="{Binding CargoFwdCapacityKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                            <Run Text=" KG FWD, "/>
                            <Run Text="{Binding CargoAftCapacityKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                            <Run Text=" KG AFT, "/>
                            <Run Text="{Binding CargoBulkCapacityKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                            <Run Text=" KG BULK"/>
                        </TextBlock>

                        <Label Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">PLANNED (KG)</Label>
                        <Label Grid.Row="1" Grid.Column="2" Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">LOADED (KG)</Label>

                        <Label Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">Cargo</Label>
                        <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding CargoPlannedKg, StringFormat={}{0:N0}}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding CargoLoadedTotalKg, StringFormat={}{0:N0}}"/>

                        <Label Grid.Row="3" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">FWD / AFT</Label>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Foreground="{DynamicResource CategoryTextBrush}" FontSize="11" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Margin="5,0,0,0"
                                   Foreground="{DynamicResource CategoryTextBrush}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="{Binding CargoFwdLoadedKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding CargoAftLoadedKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- CARGO DOORS — top-down silhouette + per-door state +
                     departure-readiness banner. The silhouette path data is
                     a public const on the model (cleaned A320 outline from
                     the user-supplied SVG), so the React panel and this
                     view share the exact same coordinate space and the
                     door rectangles land on the same fuselage positions in
                     both surfaces. Door rectangles are placed in the SVG's
                     750×750 viewBox; the Viewbox scales the whole canvas
                     to whatever width the right column ends up at. -->
                <TextBlock Style="{StaticResource CategoryHeader}" Text="CARGO DOORS" Margin="0,8,0,0"/>
                <Border Style="{StaticResource SectionCardBorder}">
                    <StackPanel Margin="6,4,6,4">

                        <!-- Silhouette + door indicators. Capped at 220 px tall
                             so a tall window doesn't blow the icon up to fill
                             the column; uniform stretch keeps the aspect. -->
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly"
                                 MaxHeight="220" HorizontalAlignment="Center">
                            <!-- Source SVG has the plane in nose-RIGHT
                                 orientation (wing leading-edge curve sweeps
                                 from fuselage at high-x toward wingtip at
                                 low-x, which is the standard aft-sweep
                                 going from nose toward tail). Rotate -90°
                                 around centre — CCW visually — so source
                                 RIGHT becomes display TOP and the plane
                                 reads nose-up. LayoutTransform (not
                                 RenderTransform) so the Viewbox measures
                                 the rotated bounds correctly. -->
                            <Canvas Width="750" Height="750">
                                <Canvas.LayoutTransform>
                                    <RotateTransform Angle="-90" CenterX="375" CenterY="375"/>
                                </Canvas.LayoutTransform>

                                <!-- Aircraft outline. Filled mid-grey so it
                                     reads as a silhouette; stroke is a thin
                                     edge in the same family for definition
                                     against the dark card background. -->
                                <Path Data="{x:Static local:ModelWeightBalance.A320OutlineGeometry}"
                                      Fill="#3F3F3F" Stroke="#7A7A7A" StrokeThickness="2"/>

                                <!-- Door rectangles in SOURCE (nose-right)
                                     coords. After -90° rotation:
                                     source HIGH x → display TOP (nose),
                                     source LOW  x → display BOTTOM (tail),
                                     source LOW  y → display LEFT (port),
                                     source HIGH y → display RIGHT (starboard).
                                     All three cargo doors sit on STARBOARD
                                     (source HIGH y) to match the real
                                     A320 — fwd, aft, and bulk are all on
                                     the right side of the airframe in real
                                     life. Long axis along source X
                                     (fore-aft) becomes vertical in display. -->

                                <!-- Forward cargo door — starboard edge,
                                     forward of wing root (high source X =
                                     closer to the nose at right). -->
                                <Rectangle Canvas.Left="498" Canvas.Top="389" Width="41" Height="14"
                                           Fill="{Binding FwdDoorBrush}"
                                           Stroke="#FFFFFF" StrokeThickness="1.2" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- Aft cargo door — starboard edge, aft of
                                     wing trailing edge (mid-low source X). -->
                                <Rectangle Canvas.Left="293" Canvas.Top="389" Width="41" Height="14"
                                           Fill="{Binding AftDoorBrush}"
                                           Stroke="#FFFFFF" StrokeThickness="1.2" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                <!-- Bulk cargo door — starboard edge, far
                                     aft (low source X, between aft cargo
                                     and tail). Hidden when the airframe
                                     has no bulk hold (CargoBulkCapacityKg = 0). -->
                                <Rectangle Canvas.Left="255" Canvas.Top="392" Width="20" Height="11"
                                           Fill="{Binding BulkDoorBrush}"
                                           Stroke="#FFFFFF" StrokeThickness="1.2"
                                           Visibility="{Binding BulkFittedVisibility}" HorizontalAlignment="Left" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Rectangle.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform/>
                                            <SkewTransform/>
                                            <RotateTransform Angle="-0.265"/>
                                            <TranslateTransform/>
                                        </TransformGroup>
                                    </Rectangle.RenderTransform>
                                </Rectangle>
                            </Canvas>
                        </Viewbox>

                        <!-- Per-door status text row — three equal cells. The
                             value text inherits the same green/amber/grey as
                             its rectangle so a quick scan picks the matching
                             door without reading the label. -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="FWD" Foreground="{DynamicResource CategoryTextBrush}"
                                           FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FwdDoorStatusText}" FontWeight="Bold" FontSize="13"
                                           Foreground="{Binding FwdDoorBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="AFT" Foreground="{DynamicResource CategoryTextBrush}"
                                           FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding AftDoorStatusText}" FontWeight="Bold" FontSize="13"
                                           Foreground="{Binding AftDoorBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="BULK" Foreground="{DynamicResource CategoryTextBrush}"
                                           FontSize="11" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding BulkDoorStatusText}" FontWeight="Bold" FontSize="13"
                                           Foreground="{Binding BulkDoorBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- Departure-readiness banner. Mirrors !HasOpenDoors
                             so it reflects the same predicate the GSX state
                             machine uses to gate CloseAllDoors() — that
                             includes pax doors, so the banner can read
                             "DOORS OPEN" while the cargo silhouette is all
                             green (pax door open during boarding). -->
                        <Border Margin="0,8,0,0" Padding="8,5,8,5" CornerRadius="3"
                                Background="{Binding ReadinessBannerBrush}">
                            <TextBlock Text="{Binding ReadinessBannerText}"
                                       Foreground="#FFFFFF" FontWeight="Bold" FontSize="13"
                                       HorizontalAlignment="Center"/>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- FUEL -->
                <TextBlock Style="{StaticResource CategoryHeader}" Text="FUEL" Margin="0,8,0,0"/>
                <Border Style="{StaticResource SectionCardBorder}">
                    <Grid Margin="6,4,6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="WbLabelCol"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" TextWrapping="Wrap"
                                   Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">
                            <Run Text="CAPACITY USABLE "/>
                            <Run Text="{Binding FuelCapacityKg, StringFormat={}{0:N0}, Mode=OneWay}"/>
                            <Run Text=" KG — SG: 0.80"/>
                        </TextBlock>

                        <Label Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">PLANNED (KG)</Label>
                        <Label Grid.Row="1" Grid.Column="2" Foreground="{DynamicResource CategoryTextBrush}" FontSize="11">IN TANKS (KG)</Label>

                        <Label Grid.Row="2" Grid.Column="0" Foreground="{DynamicResource CategoryTextBrush}">Fuel</Label>
                        <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding FuelPlannedKg, StringFormat={}{0:N0}}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,0,0"
                                   Text="{Binding FuelInTanksKg, StringFormat={}{0:N0}}"/>
                    </Grid>
                </Border>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
