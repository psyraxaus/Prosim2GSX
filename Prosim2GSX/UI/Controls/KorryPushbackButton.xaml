<UserControl x:Class="Prosim2GSX.UI.KorryPushbackButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Prosim2GSX.UI"
             mc:Ignorable="d"
             d:DesignHeight="110" d:DesignWidth="90"
             Focusable="False">

    <UserControl.Resources>
        <!-- Inactive vs active brushes for green directional arrows -->
        <SolidColorBrush x:Key="KorryArrowInactive" Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="KorryArrowGreenActive" Color="#FF00DD55"/>
        <SolidColorBrush x:Key="KorryAutoInactive" Color="#FF666666"/>
        <SolidColorBrush x:Key="KorryAutoDividerInactive" Color="#FF444444"/>
        <SolidColorBrush x:Key="KorryAutoActive" Color="#FFFFC200"/>
        <SolidColorBrush x:Key="KorryAutoDividerActive" Color="#66FFC200"/>
        <SolidColorBrush x:Key="KorryLegendInactiveText" Color="#FF333333"/>
        <SolidColorBrush x:Key="KorryGreenLegendBackground" Color="#FF050510"/>
        <SolidColorBrush x:Key="KorryGreenLegendText" Color="#FF1A8FFF"/>
        <SolidColorBrush x:Key="KorryAmberLegendBackground" Color="#FF1A1200"/>
        <SolidColorBrush x:Key="KorryAmberLegendText" Color="#FFFFC200"/>
        <SolidColorBrush x:Key="KorryBodyBackground" Color="#FF111111"/>
        <SolidColorBrush x:Key="KorryBodyBorder" Color="#FF333333"/>
        <SolidColorBrush x:Key="KorryBodyBorderActive" Color="#FF555555"/>
        <SolidColorBrush x:Key="KorryIconZoneActiveGreen" Color="#FF051A05"/>
        <SolidColorBrush x:Key="KorryIconZoneActiveAuto" Color="#FF26200A"/>
        <SolidColorBrush x:Key="KorrySubtitleBrush" Color="#FF777777"/>
    </UserControl.Resources>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
        <!-- Outer button body -->
        <Border x:Name="ButtonBody"
                Width="90" Height="82"
                CornerRadius="5"
                BorderThickness="2"
                Background="{StaticResource KorryBodyBackground}"
                BorderBrush="{StaticResource KorryBodyBorder}"
                Cursor="Hand"
                MouseLeftButtonDown="OnMouseLeftButtonDown"
                MouseLeftButtonUp="OnMouseLeftButtonUp"
                MouseLeave="OnMouseLeave">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PressTransform" Y="0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="54"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Upper icon zone -->
                <Border x:Name="IconZone"
                        Grid.Row="0"
                        Background="{StaticResource KorryBodyBackground}">
                    <Grid>
                        <!-- Tail Left arrow -->
                        <Canvas x:Name="ArrowTailLeft" Width="56" Height="44"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <Path x:Name="TailLeftCurve"
                                  Stroke="{StaticResource KorryArrowInactive}"
                                  StrokeThickness="4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 42 3 L 42 21 Q 42 37 28 37 L 20 37"/>
                            <Polygon x:Name="TailLeftHead"
                                     Fill="{StaticResource KorryArrowInactive}"
                                     Points="7,37 19,30 19,44"/>
                        </Canvas>

                        <!-- Auto (bidirectional) -->
                        <Canvas x:Name="ArrowAuto" Width="50" Height="40"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <Polygon x:Name="AutoLeftHead"
                                     Fill="{StaticResource KorryAutoInactive}"
                                     Points="2,20 13,13 13,27"/>
                            <Line x:Name="AutoLeftStem"
                                  X1="12" Y1="20" X2="25" Y2="20"
                                  Stroke="{StaticResource KorryAutoInactive}"
                                  StrokeThickness="3.5"/>
                            <Polygon x:Name="AutoRightHead"
                                     Fill="{StaticResource KorryAutoInactive}"
                                     Points="48,20 37,13 37,27"/>
                            <Line x:Name="AutoRightStem"
                                  X1="25" Y1="20" X2="38" Y2="20"
                                  Stroke="{StaticResource KorryAutoInactive}"
                                  StrokeThickness="3.5"/>
                            <Line x:Name="AutoDivider"
                                  X1="25" Y1="8" X2="25" Y2="32"
                                  Stroke="{StaticResource KorryAutoDividerInactive}"
                                  StrokeThickness="1.5"
                                  StrokeDashArray="2.5 3"/>
                        </Canvas>

                        <!-- Tail Right arrow (mirror of Tail Left) -->
                        <Canvas x:Name="ArrowTailRight" Width="56" Height="44"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <Path x:Name="TailRightCurve"
                                  Stroke="{StaticResource KorryArrowInactive}"
                                  StrokeThickness="4"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 14 3 L 14 21 Q 14 37 28 37 L 36 37"/>
                            <Polygon x:Name="TailRightHead"
                                     Fill="{StaticResource KorryArrowInactive}"
                                     Points="49,37 37,30 37,44"/>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- 1px separator between icon zone and legend strip -->
                <Border Grid.Row="1" Background="#FF222222"/>

                <!-- Lower legend strip (26px) -->
                <Border x:Name="LegendStrip" Grid.Row="2" Padding="0">
                    <Grid>
                        <Border x:Name="LegendBox"
                                BorderThickness="0"
                                CornerRadius="2"
                                Margin="6,3,6,3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Background="Transparent">
                            <TextBlock x:Name="LegendText"
                                       Text=""
                                       FontFamily="Consolas"
                                       FontSize="9"
                                       FontWeight="DemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource KorryLegendInactiveText}">
                                <TextBlock.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
                                    </Style>
                                </TextBlock.Resources>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Subtitle below body (outside) -->
        <TextBlock x:Name="SubtitleText"
                   Text=""
                   FontFamily="Consolas"
                   FontSize="9"
                   FontWeight="DemiBold"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0"
                   Foreground="{StaticResource KorrySubtitleBrush}"/>
    </StackPanel>
</UserControl>
